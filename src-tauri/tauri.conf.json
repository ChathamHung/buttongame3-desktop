{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "button-game-3",
  "version": "3.0.0",
  "identifier": "com.button-game-3.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Button Game 3 Desktop",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 687,
        "maximized": true,
        "decorations": false,
        "url": "/?app=true&appVersion=3.0&appUpdates=3&titleBar=true&appMode=offline"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
